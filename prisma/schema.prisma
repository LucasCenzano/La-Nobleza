// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ---------------------------------------------------------------
// Enums
// ---------------------------------------------------------------

enum TipoVenta {
  UNIDAD // Precio por unidad cerrada
  PESO   // Precio por kilogramo
}

// ---------------------------------------------------------------
// Modelos
// ---------------------------------------------------------------

model Producto {
  id           String    @id @default(cuid())
  nombre       String
  descripcion  String?
  precio       Float
  precioOferta Float?             // null = sin oferta activa
  categoria    String             // slug dinámico — ref a CategoriaConfig.slug
  tipoVenta    TipoVenta @default(UNIDAD)
  stock        Float?             // null = sin control de stock
  incrementoPeso Float?           // paso en kilos o gramos
  imagenUrl    String?            // legado — portada (primer elemento de imagenesUrls)
  imagenesUrls String[]           // array ordenado: [0]=portada, [1..]=adicionales
  etiquetas    String[]           // "NUEVO" | "DESTACADO" | "OFERTA" | "SIN_STOCK"
  
  // Opciones de Pedido Personalizadas
  solicitaInstrucciones Boolean @default(false)
  opcionesTitulo        String? // ej: "¿Cómo las preferís?"
  opcionesValores       String[] // ej: ["Enteras", "Fileteadas", "En dados"]
  
  // Custom text for promo, e.g. "Llevando 2kg -> $5.000"
  promoPersonalizada    String?
  
  // Custom discount rules
  promoCantidadRequerida Float?
  promoPrecioTotal       Float?
  
  activo       Boolean   @default(true)
  orden        Int       @default(0)  // posición en el catálogo (0 = primero)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("productos")
  @@index([categoria])
  @@index([activo])
}

// ---------------------------------------------------------------
// Categorías dinámicas (reemplaza el enum Categoria)
// ---------------------------------------------------------------

model CategoriaConfig {
  id        String   @id @default(cuid())
  nombre    String   // "Pollo Entero"
  slug      String   @unique // "POLLO_ENTERO" — coincide con Producto.categoria
  emoji     String   @default("🐔")
  color     String   @default("#f97316") // hex para badge
  orden     Int      @default(0)
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("categorias_config")
  @@index([orden])
}

// ---------------------------------------------------------------
// Configuración global de la tienda (banner + horarios)
// ---------------------------------------------------------------

model ConfiguracionTienda {
  id              String   @id @default("singleton")
  // Banner del catálogo
  bannerActivo    Boolean  @default(false)
  bannerTipo      String   @default("INFO")   // INFO | PROMO | ALERTA | CERRADO
  bannerTexto     String   @default("")
  bannerColor     String   @default("#f97316")
  // Horarios de atención
  horariosActivos Boolean  @default(true)
  horarios        Json?    // { lunes: {activo, abre, cierra}, ... }
  updatedAt       DateTime @updatedAt

  @@map("configuracion_tienda")
}

// ---------------------------------------------------------------
// Administradores (para autenticación básica del panel /admin)
// ---------------------------------------------------------------

model Administrador {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // Hash bcrypt
  nombre    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("administradores")
}
