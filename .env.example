# ══════════════════════════════════════════════════════════════
# La Nobleza — Variables de Entorno
# Copiá este archivo como .env.local para desarrollo local.
# Configurá TODAS estas variables en el panel de Vercel para producción.
# ⚠️  NUNCA subir .env.local a Git. Ya está en .gitignore.
# ══════════════════════════════════════════════════════════════

# ── Neon PostgreSQL ──────────────────────────────────────────
# DATABASE_URL    → usar la URL con POOLER (PgBouncer) para las queries normales
# DATABASE_URL_UNPOOLED → usar la URL SIN pooler para migraciones (prisma migrate)
# IMPORTANTE: el nombre DATABASE_URL_UNPOOLED debe coincidir con prisma/schema.prisma
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DATABASE?sslmode=require&pgbouncer=true"
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DATABASE?sslmode=require"

# ── NextAuth ─────────────────────────────────────────────────
# NEXTAUTH_SECRET → generarlo con: openssl rand -base64 32
# NEXTAUTH_URL    → en producción: https://tu-dominio.vercel.app (sin barra final)
NEXTAUTH_SECRET="REEMPLAZAR-con-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# ── Credenciales del Administrador ──────────────────────────
# Usadas por /api/init-db para crear el usuario admin inicial.
# En producción, usar una contraseña segura de al menos 16 caracteres.
ADMIN_EMAIL="admin@lanobleza.com"
ADMIN_PASSWORD="REEMPLAZAR-con-contraseña-segura-16chars+"

# ── Ruta de Inicialización de BD ─────────────────────────────
# Token para proteger GET /api/init-db?secret=...
# Generarlo con: openssl rand -hex 24
# Una vez que la BD esté inicializada en producción, ELIMINAR esta variable
# del entorno de Vercel para desactivar la ruta permanentemente.
INIT_DB_SECRET="REEMPLAZAR-con-openssl-rand-hex-24"

# ── Vercel KV (Rate Limiting) ────────────────────────────────
# Obtener desde: Vercel Dashboard → Storage → KV
KV_REST_API_URL="https://tu-kv.upstash.io"
KV_REST_API_TOKEN="tu-token-de-vercel-kv"

